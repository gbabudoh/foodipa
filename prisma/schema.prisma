generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id                 String        @id @default(cuid())
  email              String        @unique
  name               String?
  password           String?
  avatar             String?
  bio                String?
  location           String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  onboardingComplete Boolean       @default(false)
  onboardingStep     Int           @default(0)
  dietaryPrefs       String[]
  favCuisines        String[]
  flavorProfile      String[]
  
  // Subscription & AI Usage Track
  plan               String        @default("FREE")
  aiUsageCount       Int           @default(0)
  
  accounts           Account[]
  sessions           Session[]
  likes              Like[]
  posts              Post[]
  savedRecipes       SavedRecipe[]

  @@map("users")
}

model Post {
  id        String   @id @default(cuid())
  userId    String
  imageUrl  String?
  caption   String
  dishName  String?
  location  String?
  tags      String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  likes     Like[]
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("posts")
}

model Like {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@map("likes")
}

model SavedRecipe {
  id        String   @id @default(cuid())
  userId    String
  title     String
  content   String
  mode      String   @default("recipe")
  prompt    String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("saved_recipes")
}

model ScanResult {
  id         String   @id @default(cuid())
  userId     String?
  imageUrl   String?
  dish       String
  cuisine    String
  confidence Int
  result     Json
  createdAt  DateTime @default(now())

  @@map("scan_results")
}

model Place {
  id          String   @id @default(cuid())
  name        String
  cuisine     String
  rating      Float
  distance    String
  time        String
  category    String
  emoji       String
  isSponsored Boolean  @default(false)
  lat         Float?   // Real-world latitude
  lng         Float?   // Real-world longitude
  x           String   // Relative X position for mock map (e.g. "35%")
  y           String   // Relative Y position for mock map (e.g. "42%")
  tag         String?
  tagColor    String?
  createdAt   DateTime @default(now())

  @@map("places")
}
